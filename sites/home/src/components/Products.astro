---
import { type Lang, t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
---

<section class="section" id="products">
  <div class="container">
    <div class="section-header reveal">
      <h2 class="products-title">{i.products.title}</h2>
      <p class="products-subtitle">{i.products.subtitle}</p>
    </div>

    <div class="products-grid">
      <!-- Concursino -->
      <div class="product-card reveal">
        <div class="product-header">
          <div class="product-icon concursino-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>
            </svg>
          </div>
          <div>
            <h3 class="product-name">{i.products.concursino.name}</h3>
            <p class="product-tagline">{i.products.concursino.tagline}</p>
          </div>
        </div>

        <p class="product-desc">{i.products.concursino.desc}</p>

        <ul class="product-features">
          {i.products.concursino.features.map((f) => (
            <li>
              <span class="feature-check">&#10003;</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>

        <div class="product-footer">
          <a href={i.products.concursino.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary product-cta">
            {i.products.concursino.cta}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17l9.2-9.2M17 17V7H7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- FitPerson -->
      <div class="product-card reveal">
        <div class="product-header">
          <div class="product-icon fitperson-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6.5 6.5h11M6.5 17.5h11M2 12h3m14 0h3M6.5 12H4M20 12h-2.5M6.5 6.5L4 6.5M17.5 6.5L20 6.5M6.5 17.5L4 17.5M17.5 17.5L20 17.5"/>
            </svg>
          </div>
          <div>
            <h3 class="product-name">{i.products.fitperson.name}</h3>
            <p class="product-tagline">{i.products.fitperson.tagline}</p>
          </div>
        </div>

        <p class="product-desc">{i.products.fitperson.desc}</p>

        <ul class="product-features">
          {i.products.fitperson.features.map((f) => (
            <li>
              <span class="feature-check fitperson-check">&#10003;</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>

        <div class="product-footer">
          <span class="coming-soon-badge">{i.products.fitperson.cta}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .products-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-md);
  }

  .products-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 540px;
    line-height: 1.7;
    margin-bottom: var(--space-3xl);
  }

  .products-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .product-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-2xl);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .product-card:hover {
    border-color: var(--border-light);
    box-shadow: var(--shadow-md);
  }

  .product-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .product-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .product-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .concursino-icon {
    background: rgba(59, 130, 246, 0.1);
    color: #60a5fa;
  }

  .fitperson-icon {
    background: rgba(249, 115, 22, 0.1);
    color: #fb923c;
  }

  .product-name {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text);
  }

  .product-tagline {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: 2px;
  }

  .product-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .product-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    flex-grow: 1;
  }

  .product-features li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .feature-check {
    color: var(--brand-light);
    font-weight: 700;
    font-size: var(--text-xs);
    flex-shrink: 0;
  }

  .fitperson-check {
    color: #fb923c;
  }

  .product-footer {
    margin-top: auto;
  }

  .product-cta {
    font-size: var(--text-sm);
  }

  .coming-soon-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
  }
</style>
