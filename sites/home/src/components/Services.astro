---
import { type Lang, t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);

const icons = [
  // Health - heart + pulse
  `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="10" fill="var(--brand-subtle)"/>
    <path d="M20 30l-1.45-1.32C13.4 23.84 10 20.84 10 17.15c0-3.15 2.42-5.65 5.5-5.65 1.74 0 3.41.81 4.5 2.09a6.04 6.04 0 014.5-2.09c3.08 0 5.5 2.5 5.5 5.65 0 3.69-3.4 6.69-8.55 11.54L20 30z" fill="var(--brand)"/>
  </svg>`,
  // Custom apps - layers
  `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="10" fill="var(--brand-subtle)"/>
    <path d="M20 12l-9 5 9 5 9-5-9-5z" fill="var(--brand)"/>
    <path d="M11 22l9 5 9-5" stroke="var(--brand)" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.6"/>
    <path d="M11 26l9 5 9-5" stroke="var(--brand)" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.35"/>
  </svg>`,
  // Factory - org chart / process
  `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="10" fill="var(--brand-subtle)"/>
    <rect x="16" y="10" width="8" height="6" rx="1.5" fill="var(--brand)"/>
    <rect x="8" y="24" width="8" height="6" rx="1.5" fill="var(--brand)" opacity="0.6"/>
    <rect x="24" y="24" width="8" height="6" rx="1.5" fill="var(--brand)" opacity="0.6"/>
    <path d="M20 16v4m0 0l-8 4m8-4l8 4" stroke="var(--brand)" stroke-width="1.5" opacity="0.4"/>
  </svg>`,
  // Performance - gauge/speedometer
  `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="40" height="40" rx="10" fill="var(--brand-subtle)"/>
    <path d="M12 26a8 8 0 1116 0" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" fill="none"/>
    <path d="M20 26l-3-7" stroke="var(--brand)" stroke-width="2" stroke-linecap="round"/>
    <circle cx="20" cy="26" r="2" fill="var(--brand)"/>
  </svg>`,
];
---

<section class="section" id="services">
  <div class="container">
    <div class="section-header reveal">
      <h2 class="section-title">{i.services.title}</h2>
      <p class="section-subtitle">{i.services.subtitle}</p>
    </div>

    <div class="services-grid">
      {i.services.items.map((item, idx) => (
        <div class="service-card reveal">
          <div class="service-icon" set:html={icons[idx]} />
          <h3 class="service-title">{item.title}</h3>
          <p class="service-desc">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: var(--space-3xl);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-md);
  }

  .section-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 540px;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .service-card {
    padding: var(--space-xl);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .service-card:hover {
    border-color: var(--border-light);
    box-shadow: var(--shadow-md);
  }

  .service-icon {
    width: 2.5rem;
    height: 2.5rem;
    margin-bottom: var(--space-lg);
  }

  .service-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .service-title {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--space-sm);
  }

  .service-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
  }
</style>
