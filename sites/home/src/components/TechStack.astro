---
import { type Lang, t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);

const stack = {
  backend: ['Java', 'Spring Boot', 'Quarkus', 'Node.js', 'TypeScript'],
  frontend: ['Flutter', 'React', 'Astro', 'Tailwind CSS'],
  infra: ['Docker', 'GitHub Actions', 'Firebase', 'AWS', 'Nginx'],
  data: ['PostgreSQL', 'Redis', 'MongoDB'],
};
---

<section class="section" id="tech">
  <div class="container">
    <div class="section-header reveal">
      <h2 class="tech-title">{i.tech.title}</h2>
      <p class="tech-subtitle">{i.tech.subtitle}</p>
    </div>

    <div class="tech-grid">
      {Object.entries(stack).map(([key, items]) => (
        <div class="tech-category reveal">
          <h3 class="tech-cat-title">{i.tech.categories[key as keyof typeof i.tech.categories]}</h3>
          <div class="tech-items">
            {items.map((name) => (
              <span class="tech-badge">{name}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-md);
  }

  .tech-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: var(--space-3xl);
  }

  .tech-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 640px) {
    .tech-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .tech-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .tech-cat-title {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .tech-items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tech-badge {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .tech-badge:hover {
    border-color: var(--brand);
    color: var(--brand-light);
  }
</style>
