{
  "hosting": {
    "public": "sites/home/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "**", "destination": "/404.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|webp|avif)",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=2592000" }
        ]
      }
    ]
  }
}
